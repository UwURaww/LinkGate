# Password for logging into /admin. Pick something you don't reuse anywhere else.
ADMIN_PASSWORD=change-this-now

# Used to sign admin session cookies and gate-completion tokens.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string

# Created automatically when you add a Blob store in your Vercel project
# (Storage tab -> Create Database -> Blob). Vercel injects this for you on
# deploy. For local dev, copy the token from the Vercel dashboard.
BLOB_READ_WRITE_TOKEN=

# Optional: paste a Discord webhook URL to get a ping every time someone
# completes a gate. Leave blank to disable.
DISCORD_WEBHOOK_URL=
